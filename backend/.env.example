# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=cse_admin
DB_PASSWORD=changeme
DB_NAME=routine_generator
# Optional: privilege override used only by `npm run migrate`.
# Leave unset to migrate as DB_USER (requires the user to already have
# CREATE DATABASE on first run). Set to a user with full server
# privileges (typically `root`) if you want `npm run migrate` to be
# able to create the database itself.
# DB_MIGRATE_USER=root
# DB_MIGRATE_PASSWORD=

# Optional: AI assist layer (must NOT be required for core scheduling).
# When OPENROUTER_API_KEY is empty, the /generate failure handler skips
# friendly_hint enrichment and the POST /api/batches/:id/edit route
# returns 503 AI_UNAVAILABLE. All other endpoints work normally.
# Get a key at https://openrouter.ai/keys (Format: sk-or-v1-...)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxx
# Default model slug from OpenRouter. Examples: 
#   - 'google/gemma-4-26b-a4b-it:free'
#   - 'openrouter/free' (auto-routes to a random available free model)
#   - 'meta-llama/llama-3.3-70b-instruct:free'
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# Override base URL only if you proxy OpenRouter through a different host.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Per-call timeout (ms) for the AI provider's HTTP request (default: 60000)
OPENROUTER_TIMEOUT_MS=60000

# HTTP port
PORT=4000
